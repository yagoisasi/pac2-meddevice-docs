    <!-- http://example.org/meddevice#riskDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#riskDescription">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the reported risk.</rdfs:comment>
        <rdfs:label xml:lang="en">riskDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#riskIdentifier -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#riskIdentifier">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the risk in the source dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">riskIdentifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#riskName -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#riskName">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the reported risk.</rdfs:comment>
        <rdfs:label xml:lang="en">riskName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#scopeDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#scopeDescription">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of the scope of the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">scopeDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#udiDi -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#udiDi">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">UDI-DI code associated with the device.</rdfs:comment>
        <rdfs:label xml:lang="en">udiDi</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevice#ActionType -->


    <owl:Class rdf:about="http://example.org/meddevice#ActionType">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled type describing the kind of corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">Action type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#CompetentAuthority -->


    <owl:Class rdf:about="http://example.org/meddevice#CompetentAuthority">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A national competent authority responsible for regulatory oversight.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent authority</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#CorrectiveAction -->


    <owl:Class rdf:about="http://example.org/meddevice#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">An action taken to mitigate or address a reported incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Country -->


    <owl:Class rdf:about="http://example.org/meddevice#Country">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A country relevant to manufacturers, reporting, or market scope.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Device -->


    <owl:Class rdf:about="http://example.org/meddevice#Device">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A regulated device represented in the catalogue.</rdfs:comment>
        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#DeviceType -->


    <owl:Class rdf:about="http://example.org/meddevice#DeviceType">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled category describing the type of device.</rdfs:comment>
        <rdfs:label xml:lang="en">Device type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#FSCA -->


    <owl:Class rdf:about="http://example.org/meddevice#FSCA">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#CorrectiveAction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#addressesIncident"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A field safety corrective action linked to a reported incident.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#FSCAStatus -->


    <owl:Class rdf:about="http://example.org/meddevice#FSCAStatus">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled status describing the lifecycle state of an FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA status</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#IVDRFramework -->


    <owl:Class rdf:about="http://example.org/meddevice#IVDRFramework">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RegulatoryFramework"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevice#MDRFramework"/>
        <rdfs:comment xml:lang="en">The In Vitro Diagnostic Regulation framework.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR framework</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#IVDRRiskClass -->


    <owl:Class rdf:about="http://example.org/meddevice#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskClass"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevice#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">A risk class used under the IVDR framework.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR risk class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Device"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevice#MedicalDevice"/>
        <rdfs:comment xml:lang="en">An in vitro diagnostic device regulated under the IVDR framework.</rdfs:comment>
        <rdfs:label xml:lang="en">In vitro diagnostic device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Incident -->


    <owl:Class rdf:about="http://example.org/meddevice#Incident">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#relatedToRisk"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A reported incident involving a regulated device.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#IncidentType -->


    <owl:Class rdf:about="http://example.org/meddevice#IncidentType">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled category describing the type of incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MDRFramework -->


    <owl:Class rdf:about="http://example.org/meddevice#MDRFramework">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">The Medical Device Regulation framework.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR framework</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MDRRiskClass -->


    <owl:Class rdf:about="http://example.org/meddevice#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#RiskClass"/>
        <rdfs:comment xml:lang="en">A risk class used under the MDR framework.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR risk class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Manufacturer -->


    <owl:Class rdf:about="http://example.org/meddevice#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#hasCompetentAuthority"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#CompetentAuthority"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/meddevice#locatedInCountry"/>
                <owl:someValuesFrom rdf:resource="http://example.org/meddevice#Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An organization that manufactures a medical device or IVD device.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MedicalDevice -->


    <owl:Class rdf:about="http://example.org/meddevice#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:comment xml:lang="en">A medical device regulated under the MDR framework.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical device</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#MedicalEntity -->


    <owl:Class rdf:about="http://example.org/meddevice#MedicalEntity">
        <rdfs:comment xml:lang="en">Top-level domain entity used to organize the ontology.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical entity</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#NearMissIncident -->


    <owl:Class rdf:about="http://example.org/meddevice#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Incident"/>
        <owl:disjointWith rdf:resource="http://example.org/meddevice#SeriousIncident"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#ProbabilityLevel -->


    <owl:Class rdf:about="http://example.org/meddevice#ProbabilityLevel">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled level describing the probability of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Probability level</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RegulatoryFramework -->


    <owl:Class rdf:about="http://example.org/meddevice#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A regulatory framework governing the device classification.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory framework</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#Risk -->


    <owl:Class rdf:about="http://example.org/meddevice#Risk">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A reported or catalogued risk associated with a device or incident.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RiskCategory -->


    <owl:Class rdf:about="http://example.org/meddevice#RiskCategory">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled category used to group reported risks.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk category</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RiskClass -->


    <owl:Class rdf:about="http://example.org/meddevice#RiskClass">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A regulatory risk class assigned to a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk class</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#RiskType -->


    <owl:Class rdf:about="http://example.org/meddevice#RiskType">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled type describing the nature of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk type</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/meddevice#SeriousIncident -->


    <owl:Class rdf:about="http://example.org/meddevice#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#Incident"/>
    </owl:Class>
    


    <!-- http://example.org/meddevice#SeverityLevel -->


    <owl:Class rdf:about="http://example.org/meddevice#SeverityLevel">
        <rdfs:subClassOf rdf:resource="http://example.org/meddevice#MedicalEntity"/>
        <rdfs:comment xml:lang="en">A controlled level describing the severity of a risk.</rdfs:comment>
        <rdfs:label xml:lang="en">Severity level</rdfs:label>
    </owl:Class>
    


