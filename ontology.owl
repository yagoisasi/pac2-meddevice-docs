        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Description of the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">fscaDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#fscaIdentifier -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#fscaIdentifier">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the field safety corrective action in the source dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">fscaIdentifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#fscaReference -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#fscaReference">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reference code for the field safety corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">fscaReference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#imdrfCode -->


