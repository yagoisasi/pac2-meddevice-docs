        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IMDRF code associated with the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">imdrfCode</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#incidentDescription -->


