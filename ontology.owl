        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the incident in the source dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">incidentIdentifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#incidentReference -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#incidentReference">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">External or EUDAMED reference for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">incidentReference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#intendedPurpose">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Intended purpose of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">intendedPurpose</rdfs:label>
    </owl:DatatypeProperty>
    


