<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/meddevice#"
     xml:base="http://example.org/meddevice"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:meddevice="http://example.org/meddevice#">
    <owl:Ontology rdf:about="http://example.org/meddevice#">
        <rdfs:comment xml:lang="en">Starter ontology generated from the five PAC2 CSV files for use in Protégé.</rdfs:comment>
        <rdfs:label xml:lang="en">European High-Risk Medical Devices and IVD Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevice#addressesIncident -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#addressesIncident">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:comment xml:lang="en">Links an FSCA to the incident it addresses.</rdfs:comment>
        <rdfs:label xml:lang="en">addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#affectsDeviceType">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#DeviceType"/>
        <rdfs:comment xml:lang="en">Links a risk to the type of device it affects.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasActionType -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasActionType">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#ActionType"/>
        <rdfs:comment xml:lang="en">Links an FSCA to its action type.</rdfs:comment>
        <rdfs:label xml:lang="en">has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasCompetentAuthority -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasCompetentAuthority">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Links a manufacturer to its competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">has competent authority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasDeviceType">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#DeviceType"/>
        <rdfs:comment xml:lang="en">Links a device to its device type.</rdfs:comment>
        <rdfs:label xml:lang="en">has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasManufacturer">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasProbability -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasProbability">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#ProbabilityLevel"/>
        <rdfs:comment xml:lang="en">Links a risk to its probability level.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskCategory">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskCategory"/>
        <rdfs:comment xml:lang="en">Links a risk to its risk category.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskClass">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasRiskType -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasRiskType">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RiskType"/>
        <rdfs:comment xml:lang="en">Links a risk to its risk type.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasSeverity -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasSeverity">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#SeverityLevel"/>
        <rdfs:comment xml:lang="en">Links a risk to its severity level.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#hasStatus -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#hasStatus">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#FSCAStatus"/>
        <rdfs:comment xml:lang="en">Links an FSCA to its lifecycle status.</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#involvesDevice">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:comment xml:lang="en">Links an incident to the device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#locatedInCountry -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#locatedInCountry">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Links an organization to the country where it is located.</rdfs:comment>
        <rdfs:label xml:lang="en">located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#regulatedUnder -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#regulatedUnder">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Links a device to the regulatory framework under which it is classified.</rdfs:comment>
        <rdfs:label xml:lang="en">regulated under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#relatedToRisk -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#relatedToRisk">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Risk"/>
        <rdfs:comment xml:lang="en">Links an incident to the risk reported.</rdfs:comment>
        <rdfs:label xml:lang="en">related to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#reportedBy -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#reportedBy">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links an incident to the organization that reported it.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/meddevice#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://example.org/meddevice#reportedInCountry">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://example.org/meddevice#Country"/>
        <rdfs:comment xml:lang="en">Links an incident to the country where it was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://example.org/meddevice#actionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#actionDate">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label xml:lang="en">actionDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#authorizationNumber">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authorization number associated with the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorizationNumber</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#closureDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#closureDate">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the corrective action was closed.</rdfs:comment>
        <rdfs:label xml:lang="en">closureDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#contactEmail">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contact email address for the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contactEmail</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#correctiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#correctiveActionTaken">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Indicates whether a corrective action was taken for the incident.</rdfs:comment>
        <rdfs:label xml:lang="en">correctiveActionTaken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#countriesAffectedText -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#countriesAffectedText">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of the countries affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">countriesAffectedText</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#detectionDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#detectionDate">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the incident was detected.</rdfs:comment>
        <rdfs:label xml:lang="en">detectionDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#deviceIdentifier -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#deviceIdentifier">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Identifier of the device in the source dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">deviceIdentifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#deviceName -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#deviceName">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial or reported name of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">deviceName</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#devicesAffectedText -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#devicesAffectedText">
        <rdfs:domain rdf:resource="http://example.org/meddevice#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of the devices affected by the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">devicesAffectedText</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#eudamedSrn -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#eudamedSrn">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number recorded for the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">eudamedSrn</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#eventDate -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#eventDate">
        <rdfs:domain rdf:resource="http://example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date on which the incident event occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">eventDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#fscaDescription -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#fscaDescription">
