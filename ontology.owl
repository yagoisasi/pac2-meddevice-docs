        <rdfs:label xml:lang="en">incidentDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/meddevice#incidentIdentifier -->


    <owl:DatatypeProperty rdf:about="http://example.org/meddevice#incidentIdentifier">
