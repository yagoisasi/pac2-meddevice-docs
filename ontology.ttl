@prefix : <http://example.org/meddevice#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/meddevice#> .

<http://example.org/meddevice#> rdf:type owl:Ontology ;
                                 rdfs:comment "Starter ontology generated from the five PAC2 CSV files for use in Protégé."@en ;
                                 rdfs:label "European High-Risk Medical Devices and IVD Ontology"@en .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://example.org/meddevice#addressesIncident
:addressesIncident rdf:type owl:ObjectProperty ;
                   rdfs:domain :FSCA ;
                   rdfs:range :Incident ;
                   rdfs:comment "Links an FSCA to the incident it addresses."@en ;
                   rdfs:label "addresses incident"@en .


###  http://example.org/meddevice#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:comment "Links a risk to the type of device it affects."@en ;
                   rdfs:label "affects device type"@en .


###  http://example.org/meddevice#hasActionType
:hasActionType rdf:type owl:ObjectProperty ;
               rdfs:domain :FSCA ;
               rdfs:range :ActionType ;
               rdfs:comment "Links an FSCA to its action type."@en ;
               rdfs:label "has action type"@en .


###  http://example.org/meddevice#hasCompetentAuthority
:hasCompetentAuthority rdf:type owl:ObjectProperty ;
                       rdfs:domain :Manufacturer ;
                       rdfs:range :CompetentAuthority ;
                       rdfs:comment "Links a manufacturer to its competent authority."@en ;
                       rdfs:label "has competent authority"@en .


###  http://example.org/meddevice#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Links a device to its device type."@en ;
               rdfs:label "has device type"@en .


###  http://example.org/meddevice#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Links a device to its manufacturer."@en ;
                 rdfs:label "has manufacturer"@en .


###  http://example.org/meddevice#hasProbability
:hasProbability rdf:type owl:ObjectProperty ;
                rdfs:domain :Risk ;
                rdfs:range :ProbabilityLevel ;
                rdfs:comment "Links a risk to its probability level."@en ;
                rdfs:label "has probability"@en .


###  http://example.org/meddevice#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :RiskCategory ;
                 rdfs:comment "Links a risk to its risk category."@en ;
                 rdfs:label "has risk category"@en .


###  http://example.org/meddevice#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Links a device to its regulatory risk class."@en ;
              rdfs:label "has risk class"@en .


###  http://example.org/meddevice#hasRiskType
:hasRiskType rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :RiskType ;
             rdfs:comment "Links a risk to its risk type."@en ;
             rdfs:label "has risk type"@en .


###  http://example.org/meddevice#hasSeverity
:hasSeverity rdf:type owl:ObjectProperty ;
             rdfs:domain :Risk ;
             rdfs:range :SeverityLevel ;
             rdfs:comment "Links a risk to its severity level."@en ;
             rdfs:label "has severity"@en .


###  http://example.org/meddevice#hasStatus
:hasStatus rdf:type owl:ObjectProperty ;
           rdfs:domain :FSCA ;
           rdfs:range :FSCAStatus ;
           rdfs:comment "Links an FSCA to its lifecycle status."@en ;
           rdfs:label "has status"@en .


###  http://example.org/meddevice#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Links an incident to the device involved."@en ;
                rdfs:label "involves device"@en .


###  http://example.org/meddevice#locatedInCountry
:locatedInCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range :Country ;
                  rdfs:comment "Links an organization to the country where it is located."@en ;
                  rdfs:label "located in country"@en .


###  http://example.org/meddevice#regulatedUnder
:regulatedUnder rdf:type owl:ObjectProperty ;
                rdfs:domain :Device ;
                rdfs:range :RegulatoryFramework ;
                rdfs:comment "Links a device to the regulatory framework under which it is classified."@en ;
                rdfs:label "regulated under"@en .


###  http://example.org/meddevice#relatedToRisk
:relatedToRisk rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :Risk ;
               rdfs:comment "Links an incident to the risk reported."@en ;
               rdfs:label "related to risk"@en .


###  http://example.org/meddevice#reportedBy
:reportedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer ;
            rdfs:comment "Links an incident to the organization that reported it."@en ;
            rdfs:label "reported by"@en .


###  http://example.org/meddevice#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country ;
                   rdfs:comment "Links an incident to the country where it was reported."@en ;
                   rdfs:label "reported in country"@en .


#################################################################
#    Data properties
#################################################################

###  http://example.org/meddevice#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :FSCA ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the corrective action was initiated."@en ;
            rdfs:label "actionDate"@en .


###  http://example.org/meddevice#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Authorization number associated with the manufacturer."@en ;
                     rdfs:label "authorizationNumber"@en .


###  http://example.org/meddevice#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :FSCA ;
             rdfs:range xsd:date ;
             rdfs:comment "Date on which the corrective action was closed."@en ;
             rdfs:label "closureDate"@en .


###  http://example.org/meddevice#contactEmail
:contactEmail rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Contact email address for the manufacturer."@en ;
              rdfs:label "contactEmail"@en .


###  http://example.org/meddevice#correctiveActionTaken
:correctiveActionTaken rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Indicates whether a corrective action was taken for the incident."@en ;
                       rdfs:label "correctiveActionTaken"@en .


###  http://example.org/meddevice#countriesAffectedText
:countriesAffectedText rdf:type owl:DatatypeProperty ;
                       rdfs:domain :FSCA ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Textual description of the countries affected by the corrective action."@en ;
                       rdfs:label "countriesAffectedText"@en .


###  http://example.org/meddevice#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date on which the incident was detected."@en ;
               rdfs:label "detectionDate"@en .


###  http://example.org/meddevice#deviceIdentifier
:deviceIdentifier rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Identifier of the device in the source dataset."@en ;
                  rdfs:label "deviceIdentifier"@en .


###  http://example.org/meddevice#deviceName
:deviceName rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "Commercial or reported name of the device."@en ;
            rdfs:label "deviceName"@en .


###  http://example.org/meddevice#devicesAffectedText
:devicesAffectedText rdf:type owl:DatatypeProperty ;
                     rdfs:domain :FSCA ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Textual description of the devices affected by the corrective action."@en ;
                     rdfs:label "devicesAffectedText"@en .


###  http://example.org/meddevice#eudamedSrn
:eudamedSrn rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "Single Registration Number recorded for the manufacturer."@en ;
            rdfs:label "eudamedSrn"@en .


###  http://example.org/meddevice#eventDate
:eventDate rdf:type owl:DatatypeProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "Date on which the incident event occurred."@en ;
           rdfs:label "eventDate"@en .


###  http://example.org/meddevice#fscaDescription
:fscaDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :FSCA ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Description of the field safety corrective action."@en ;
                 rdfs:label "fscaDescription"@en .


###  http://example.org/meddevice#fscaIdentifier
:fscaIdentifier rdf:type owl:DatatypeProperty ;
                rdfs:domain :FSCA ;
                rdfs:range xsd:string ;
                rdfs:comment "Identifier of the field safety corrective action in the source dataset."@en ;
                rdfs:label "fscaIdentifier"@en .


###  http://example.org/meddevice#fscaReference
:fscaReference rdf:type owl:DatatypeProperty ;
               rdfs:domain :FSCA ;
               rdfs:range xsd:string ;
               rdfs:comment "Reference code for the field safety corrective action."@en ;
               rdfs:label "fscaReference"@en .


###  http://example.org/meddevice#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "IMDRF code associated with the risk."@en ;
           rdfs:label "imdrfCode"@en .


###  http://example.org/meddevice#incidentDescription
:incidentDescription rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Narrative description of the incident."@en ;
                     rdfs:label "incidentDescription"@en .


###  http://example.org/meddevice#incidentIdentifier
:incidentIdentifier rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Identifier of the incident in the source dataset."@en ;
                    rdfs:label "incidentIdentifier"@en .


###  http://example.org/meddevice#incidentReference
:incidentReference rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range xsd:string ;
                   rdfs:comment "External or EUDAMED reference for the incident."@en ;
                   rdfs:label "incidentReference"@en .


###  http://example.org/meddevice#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Intended purpose of the device."@en ;
                 rdfs:label "intendedPurpose"@en .


###  http://example.org/meddevice#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device is active."@en ;
          rdfs:label "isActive"@en .


###  http://example.org/meddevice#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is implantable."@en ;
               rdfs:label "isImplantable"@en .


###  http://example.org/meddevice#isIvd
:isIvd rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Indicates whether the device is an in vitro diagnostic device."@en ;
       rdfs:label "isIvd"@en .


###  http://example.org/meddevice#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is reusable."@en ;
            rdfs:label "isReusable"@en .


###  http://example.org/meddevice#manufacturerIdentifier
:manufacturerIdentifier rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Manufacturer ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Identifier of the manufacturer in the source dataset."@en ;
                        rdfs:label "manufacturerIdentifier"@en .


###  http://example.org/meddevice#manufacturerName
:manufacturerName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Official name of the manufacturer."@en ;
                  rdfs:label "manufacturerName"@en .


###  http://example.org/meddevice#outcomeDescription
:outcomeDescription rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Reported outcome associated with the incident."@en ;
                    rdfs:label "outcomeDescription"@en .


###  http://example.org/meddevice#patientAge
:patientAge rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:integer ;
            rdfs:comment "Age of the patient associated with the reported incident."@en ;
            rdfs:label "patientAge"@en .


###  http://example.org/meddevice#patientSex
:patientSex rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Sex of the patient associated with the reported incident."@en ;
            rdfs:label "patientSex"@en .


###  http://example.org/meddevice#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the incident was officially reported."@en ;
            rdfs:label "reportDate"@en .


###  http://example.org/meddevice#riskDescription
:riskDescription rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Description of the reported risk."@en ;
                 rdfs:label "riskDescription"@en .


###  http://example.org/meddevice#riskIdentifier
:riskIdentifier rdf:type owl:DatatypeProperty ;
                rdfs:domain :Risk ;
                rdfs:range xsd:string ;
                rdfs:comment "Identifier of the risk in the source dataset."@en ;
                rdfs:label "riskIdentifier"@en .


###  http://example.org/meddevice#riskName
:riskName rdf:type owl:DatatypeProperty ;
          rdfs:domain :Risk ;
          rdfs:range xsd:string ;
          rdfs:comment "Name of the reported risk."@en ;
          rdfs:label "riskName"@en .


###  http://example.org/meddevice#scopeDescription
:scopeDescription rdf:type owl:DatatypeProperty ;
                  rdfs:domain :FSCA ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Textual description of the scope of the corrective action."@en ;
                  rdfs:label "scopeDescription"@en .


###  http://example.org/meddevice#udiDi
:udiDi rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:string ;
       rdfs:comment "UDI-DI code associated with the device."@en ;
       rdfs:label "udiDi"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/meddevice#ActionType
:ActionType rdf:type owl:Class ;
            rdfs:subClassOf :MedicalEntity ;
            rdfs:comment "A controlled type describing the kind of corrective action."@en ;
            rdfs:label "Action type"@en .


###  http://example.org/meddevice#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:subClassOf :MedicalEntity ;
                    rdfs:comment "A national competent authority responsible for regulatory oversight."@en ;
                    rdfs:label "Competent authority"@en .


###  http://example.org/meddevice#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf :MedicalEntity ;
                  rdfs:comment "An action taken to mitigate or address a reported incident."@en ;
                  rdfs:label "Corrective action"@en .


###  http://example.org/meddevice#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :MedicalEntity ;
         rdfs:comment "A country relevant to manufacturers, reporting, or market scope."@en ;
         rdfs:label "Country"@en .


###  http://example.org/meddevice#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf :MedicalEntity ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:someValuesFrom :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:someValuesFrom :RiskClass
                        ] ;
        rdfs:comment "A regulated device represented in the catalogue."@en ;
        rdfs:label "Device"@en .


###  http://example.org/meddevice#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:subClassOf :MedicalEntity ;
            rdfs:comment "A controlled category describing the type of device."@en ;
            rdfs:label "Device type"@en .


###  http://example.org/meddevice#FSCA
:FSCA rdf:type owl:Class ;
      rdfs:subClassOf :CorrectiveAction ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :addressesIncident ;
                        owl:someValuesFrom :Incident
                      ] ;
      rdfs:comment "A field safety corrective action linked to a reported incident."@en ;
      rdfs:label "FSCA"@en .


###  http://example.org/meddevice#FSCAStatus
:FSCAStatus rdf:type owl:Class ;
            rdfs:subClassOf :MedicalEntity ;
            rdfs:comment "A controlled status describing the lifecycle state of an FSCA."@en ;
            rdfs:label "FSCA status"@en .


###  http://example.org/meddevice#IVDRFramework
:IVDRFramework rdf:type owl:Class ;
               rdfs:subClassOf :RegulatoryFramework ;
               owl:disjointWith :MDRFramework ;
               rdfs:comment "The In Vitro Diagnostic Regulation framework."@en ;
               rdfs:label "IVDR framework"@en .


###  http://example.org/meddevice#IVDRRiskClass
:IVDRRiskClass rdf:type owl:Class ;
               rdfs:subClassOf :RiskClass ;
               owl:disjointWith :MDRRiskClass ;
               rdfs:comment "A risk class used under the IVDR framework."@en ;
               rdfs:label "IVDR risk class"@en .


###  http://example.org/meddevice#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         owl:disjointWith :MedicalDevice ;
                         rdfs:comment "An in vitro diagnostic device regulated under the IVDR framework."@en ;
                         rdfs:label "In vitro diagnostic device"@en .


###  http://example.org/meddevice#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesDevice ;
                            owl:someValuesFrom :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :relatedToRisk ;
                            owl:someValuesFrom :Risk
                          ] ;
          rdfs:comment "A reported incident involving a regulated device."@en ;
          rdfs:label "Incident"@en .


###  http://example.org/meddevice#IncidentType
:IncidentType rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ;
              rdfs:comment "A controlled category describing the type of incident."@en ;
              rdfs:label "Incident type"@en .


###  http://example.org/meddevice#MDRFramework
:MDRFramework rdf:type owl:Class ;
              rdfs:subClassOf :RegulatoryFramework ;
              rdfs:comment "The Medical Device Regulation framework."@en ;
              rdfs:label "MDR framework"@en .


###  http://example.org/meddevice#MDRRiskClass
:MDRRiskClass rdf:type owl:Class ;
              rdfs:subClassOf :RiskClass ;
              rdfs:comment "A risk class used under the MDR framework."@en ;
              rdfs:label "MDR risk class"@en .


###  http://example.org/meddevice#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCompetentAuthority ;
                                owl:someValuesFrom :CompetentAuthority
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :locatedInCountry ;
                                owl:someValuesFrom :Country
                              ] ;
              rdfs:comment "An organization that manufactures a medical device or IVD device."@en ;
              rdfs:label "Manufacturer"@en .


###  http://example.org/meddevice#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf :Device ;
               rdfs:comment "A medical device regulated under the MDR framework."@en ;
               rdfs:label "Medical device"@en .


###  http://example.org/meddevice#MedicalEntity
:MedicalEntity rdf:type owl:Class ;
               rdfs:comment "Top-level domain entity used to organize the ontology."@en ;
               rdfs:label "Medical entity"@en .


###  http://example.org/meddevice#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  owl:disjointWith :SeriousIncident .


###  http://example.org/meddevice#ProbabilityLevel
:ProbabilityLevel rdf:type owl:Class ;
                  rdfs:subClassOf :MedicalEntity ;
                  rdfs:comment "A controlled level describing the probability of a risk."@en ;
                  rdfs:label "Probability level"@en .


###  http://example.org/meddevice#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:subClassOf :MedicalEntity ;
                     rdfs:comment "A regulatory framework governing the device classification."@en ;
                     rdfs:label "Regulatory framework"@en .


###  http://example.org/meddevice#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf :MedicalEntity ;
      rdfs:comment "A reported or catalogued risk associated with a device or incident."@en ;
      rdfs:label "Risk"@en .


###  http://example.org/meddevice#RiskCategory
:RiskCategory rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ;
              rdfs:comment "A controlled category used to group reported risks."@en ;
              rdfs:label "Risk category"@en .


###  http://example.org/meddevice#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:subClassOf :MedicalEntity ;
           rdfs:comment "A regulatory risk class assigned to a device."@en ;
           rdfs:label "Risk class"@en .


###  http://example.org/meddevice#RiskType
:RiskType rdf:type owl:Class ;
          rdfs:subClassOf :MedicalEntity ;
          rdfs:comment "A controlled type describing the nature of a risk."@en ;
          rdfs:label "Risk type"@en .


###  http://example.org/meddevice#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident .


###  http://example.org/meddevice#SeverityLevel
:SeverityLevel rdf:type owl:Class ;
               rdfs:subClassOf :MedicalEntity ;
               rdfs:comment "A controlled level describing the severity of a risk."@en ;
               rdfs:label "Severity level"@en .


#################################################################
#    Individuals
#################################################################

###  http://example.org/meddevice#Authority_Agence_f_d_rale_des_m_dicaments_et_des_produits_de_sant_AFMPS
:Authority_Agence_f_d_rale_des_m_dicaments_et_des_produits_de_sant_AFMPS rdf:type owl:NamedIndividual ,
                                                                                  :CompetentAuthority ;
                                                                         rdfs:label "Agence fédérale des médicaments et des produits de santé (AFMPS)"@en .


###  http://example.org/meddevice#Authority_Agence_nationale_de_s_curit_du_m_dicament_ANSM
:Authority_Agence_nationale_de_s_curit_du_m_dicament_ANSM rdf:type owl:NamedIndividual ,
                                                                   :CompetentAuthority ;
                                                          rdfs:label "Agence nationale de sécurité du médicament (ANSM)"@en .


###  http://example.org/meddevice#Authority_Bundesinstitut_f_r_Arzneimittel_und_Medizinprodukte_BfArM
:Authority_Bundesinstitut_f_r_Arzneimittel_und_Medizinprodukte_BfArM rdf:type owl:NamedIndividual ,
                                                                              :CompetentAuthority ;
                                                                     rdfs:label "Bundesinstitut für Arzneimittel und Medizinprodukte (BfArM)"@en .


###  http://example.org/meddevice#Authority_Health_Products_Regulatory_Authority_HPRA
:Authority_Health_Products_Regulatory_Authority_HPRA rdf:type owl:NamedIndividual ,
                                                              :CompetentAuthority ;
                                                     rdfs:label "Health Products Regulatory Authority (HPRA)"@en .


###  http://example.org/meddevice#Authority_L_kemedelsverket_MPA
