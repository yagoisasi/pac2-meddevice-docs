              :hasRiskCategory :RiskCategory_Device_Failure ;
              :hasRiskType :RiskType_MalfunctionRisk ;
              :hasSeverity :Severity_Critical ;
              :imdrfCode "A0101" ;
              :riskDescription "Complete loss of electrical function leading to device shutdown" ;
